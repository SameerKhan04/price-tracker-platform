# ─── Flask ───────────────────────────────────────────────
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Options: development, testing, production
FLASK_ENV=development

# ─── Database ────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://pricetracker:password@db:5432/pricetracker

# ─── Redis / Celery ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Scraper settings ────────────────────────────────────
# How long to wait (seconds) before a scrape request times out
SCRAPER_TIMEOUT=10

# Delay between scrape requests to be respectful (seconds)
SCRAPER_DELAY=2

# ─── Admin ───────────────────────────────────────────────
# Email address that gets admin privileges on first registration
ADMIN_EMAIL=admin@example.com
